<!DOCTYPE html>
<html>
<head>
  <title>Creative Technologies Catalogue</title>
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>

  <%= stylesheet_link_tag    'application', media: 'all', 'data-turbolinks-track': 'reload' %>
  <%= javascript_include_tag 'application', 'data-turbolinks-track': 'reload' %>

  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
</head>

<body>
<div class="header-line">&nbsp;</div>
  <nav class="navbar">
    <div class="left-block">
      <div class="logo">
        <a href="/"><%= image_tag 'logo.svg', alt: 'Creative Electronic Technology' %></a>
      </div>
      <div class="nav-title">
        <p class="nav-element-text text-bold">
          <%= link_to 'Creative Electronic Technology', root_path %>
        </p>
      </div>
    </div>
    <div class="right-block">
      <div class="nav-element-text nav-right-link text-semi-bold mr-sm">
        <a href="#" id="navToggle">Навигация <i class="fa-solid fa-chevron-down"></i></a>
        <ul class="dropdown-menu" id="navMenu">
          <li><a href="#catalogue">Каталог</a></li>
          <li><a href="#about">О компании</a></li>
          <li><a href="#payments">Оплата и доставка</a></li>
        </ul>
      </div>
      <div class="nav-element-text nav-right-link text-semi-bold">
        <a href="#contacts">Контакты</a>
      </div>
    </div>
  </nav>

<div class="container mt-sm">
  <% if flash[:notice].present? %>
    <p class="mb mt message message-notice"><%= flash[:notice] %></p>
  <% elsif flash[:alert].present? %>
    <p class="mb mt message message-alert"><%= flash[:alert] %></p>
  <% end %>

  <%= yield %>

  <footer class="footer">
    <p>&copy; 2023-2025 Createhnologies. Все права защищены.</p>
  </footer>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const containers = document.querySelectorAll('.parallax-container');
    const speed     = 0.5;
    const maxOffset = 50;

    function clamp(val, min, max) {
      return Math.min(Math.max(val, min), max);
    }

    function updateParallax() {
      const windowH = window.innerHeight;

      containers.forEach(container => {
        const textBlock = container.querySelector('.parallax-text');
        const rect      = container.getBoundingClientRect();

        if (rect.bottom < 0 || rect.top > windowH) return;
        const rawMove = ( (windowH - rect.top) * speed )
          - (rect.height * speed / 2);

        const moveY = clamp(rawMove, -maxOffset, maxOffset);

        // Центрируем по X и сдвигаем по Y в пределах maxOffset
        textBlock.style.transform =
          `translateY(calc(-50% + ${moveY}px))`;
      });
    }

    window.addEventListener('scroll', updateParallax);
    window.addEventListener('resize', updateParallax);
    updateParallax();
  });
</script>
<script>
  console.log('toggle click')
  document.addEventListener('DOMContentLoaded', () => {
    const toggleLink = document.getElementById('navToggle');
    const menu       = document.getElementById('navMenu');
    const icon       = toggleLink.querySelector('i');

    toggleLink.addEventListener('click', (e) => {
      e.preventDefault();
      // переключаем видимость меню
      menu.classList.toggle('show');
      // меняем стрелку
      icon.classList.toggle('fa-chevron-down');
      icon.classList.toggle('fa-chevron-up');
    });

    // Скрывать меню при клике вне его
    document.addEventListener('click', (e) => {
      if (!toggleLink.contains(e.target) && !menu.contains(e.target)) {
        if (menu.classList.contains('show')) {
          menu.classList.remove('show');
          icon.classList.add('fa-chevron-down');
          icon.classList.remove('fa-chevron-up');
        }
      }
    });
  });
</script>
<script>
  document.addEventListener('DOMContentLoaded', () => {
    const container = document.querySelector('.star-rating');
    const labels    = Array.from(container.querySelectorAll('.star-label'));
    const inputs    = Array.from(container.querySelectorAll('.star-input'));

    labels.forEach(label => {
      label.addEventListener('click', () => {
        const val = parseInt(label.dataset.value, 10);

        inputs.forEach(input => {
          input.checked = parseInt(input.value, 10) === val;
        });

        labels.forEach(l => {
          const lval = parseInt(l.dataset.value, 10);
          if (lval <= val) l.classList.add('selected');
          else             l.classList.remove('selected');
        });

        container.classList.add('has-selection');
      });
    });
  });
</script>
</body>
</html>
