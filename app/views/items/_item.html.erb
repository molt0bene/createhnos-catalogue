<div class="item-card">
  <div class="item-image">
    <% if item.image_paths.present? %>
      <img src="<%= asset_path(item.image_paths.first) %>" alt="<%= item.name %>" class="item-image">
    <% else %>
      <img src="<%= asset_path("default.jpg") %>" alt="Default Image" class="item-image">
    <% end %>
  </div>

  <div class="item-rating">
    <% full_stars = item.average_rating.floor %>
    <% has_half_star = (item.average_rating - full_stars >= 0.25 && item.average_rating - full_stars < 0.75) %>
    <% empty_stars = 5 - full_stars - (has_half_star ? 1 : 0) %>

    <% full_stars.times do %>
      <i class="fa-solid fa-star"></i>
    <% end %>

    <% if has_half_star %>
      <i class="fa-solid fa-star-half-stroke"></i>
    <% end %>

    <% empty_stars.times do %>
      <i class="fa-regular fa-star"></i>
    <% end %>
  </div>

  <h2 class="item-card-title"><%= link_to item.name, item_path(item) %></h2>

  <div class="item-price-footer">
    <span class="item-footer-element text-bold"><%= number_with_delimiter(item.price.to_i) %><span class="currency-symbol">₽</span></span>
    <span class="item-footer-element text-lighter item-footer-article"><%= item.article || "101456323" %></span>

    <%= link_to item_path(item), class: "btn btn-view" do %>
      Подробнее <i class="fa-solid fa-angle-right"></i>
    <% end %>
  </div>
</div>
