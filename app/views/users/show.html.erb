<h1>Профиль</h1>

<div class="user-profile">
  <h2><%= @user.name %></h2>
  <p>Email: <%= @user.email %></p>
  <p>Joined: <%= @user.created_at.strftime('%B %d, %Y') %></p>

  <h3>Товары, добавленные пользователем <%= @user.name %></h3>
  <ul class="item-list">
    <% @user.items.each do |item| %>
      <li>
        <%= link_to item.name, item_path(item) %> - <%= number_to_currency(item.price) %>
      </li>
    <% end %>
  </ul>
</div>
